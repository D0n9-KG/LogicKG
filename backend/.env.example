# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=please_change_me

# LLM (default: DeepSeek OpenAI-compatible)
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=
LLM_MODEL=deepseek-chat
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_TIMEOUT_SECONDS=60
# Keep this at 0 by default because outer tenacity retry already does 3 attempts.
# Set to 1 only if your provider is very flaky and you can tolerate longer tail latency.
# LLM_CLIENT_MAX_RETRIES=0
# INGEST_LLM_MAX_WORKERS=4
# INGEST_LLM_HEARTBEAT_SECONDS=20
# NEO4J_CONNECTION_TIMEOUT_SECONDS=15

# Embeddings (required for RAG, similarity, clustering, and FAISS)
# Recommended: SiliconFlow BAAI/bge-m3
EMBEDDING_PROVIDER=siliconflow
SILICONFLOW_API_KEY=
EMBEDDING_MODEL=BAAI/bge-m3
# EMBEDDING_BASE_URL=https://api.siliconflow.com/v1

# Paths
DATA_ROOT=..
