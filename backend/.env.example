# Backend-local override example.
# The app reads `backend/.env` first, then falls back to the repo-root `.env`.

# Neo4j
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
# NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=please_change_me

# LLM
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-chat
LLM_API_KEY=
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_TIMEOUT_SECONDS=60
# Keep this at 0 by default because outer tenacity retry already does 3 attempts.
# Set to 1 only if your provider is very flaky and you can tolerate longer tail latency.
# LLM_CLIENT_MAX_RETRIES=0
# INGEST_LLM_MAX_WORKERS=5
# INGEST_LLM_HEARTBEAT_SECONDS=20
# NEO4J_CONNECTION_TIMEOUT_SECONDS=15
# PHASE1_CHUNK_CLAIM_MAX_WORKERS=4
# PHASE1_GROUNDING_MAX_WORKERS=3
# PHASE2_CONFLICT_MAX_WORKERS=3
# INGEST_PRE_LLM_MAX_WORKERS=6
# FAISS_EMBED_MAX_WORKERS=4
# LLM_GLOBAL_MAX_CONCURRENT=32
# CROSSREF_MAILTO=ops@example.com
# CROSSREF_USER_AGENT=LogicKG/1.0
# CROSSREF_MAX_CONCURRENT=2
# CROSSREF_MIN_INTERVAL_SECONDS=0.12

# Embeddings
EMBEDDING_PROVIDER=siliconflow
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_API_KEY=
SILICONFLOW_API_KEY=
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1

# Optional tuning
EVOLUTION_MIN_COVERAGE=0.5
DATA_ROOT=..
