# =========================
# LogicKG example config (repo root)
# =========================
#
# Usage:
# 1. Copy this file to `.env`
# 2. Fill in your local credentials
# 3. Never commit the real `.env`
#
# The backend reads `backend/.env` first and then the repo-root `.env`.
# For this project, keeping the real config in the repo root is the most convenient.

# ---- Neo4j ----
# Either `NEO4J_USER` or `NEO4J_USERNAME` works.
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
# NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=please_change_me

# ---- Textbook / autoyoutu ----
# Absolute path recommended so the backend can always find the sibling project.
AUTOYOUTU_DIR=C:/path/to/autoyoutu

# ---- LLM ----
# Supported providers include: deepseek / openai / openrouter
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-chat

# Recommended: use one generic key OR one provider-specific key.
LLM_API_KEY=
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# Optional custom endpoint
# LLM_BASE_URL=https://api.deepseek.com/v1

# ---- Embeddings ----
# Required for RAG, similarity, clustering, and FAISS-related features.
EMBEDDING_PROVIDER=siliconflow
EMBEDDING_MODEL=BAAI/bge-m3

# You may use either the generic embedding key or a provider-specific key.
EMBEDDING_API_KEY=
SILICONFLOW_API_KEY=
EMBEDDING_BASE_URL=https://api.siliconflow.com/v1

# ---- Optional tuning ----
EVOLUTION_MIN_COVERAGE=0.5
# DATA_ROOT=..
# PHASE1_GATE_ALLOW_WEAK=false
