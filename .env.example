# =========================
# LogicKG 示例配置（根目录）
# =========================
#
# 说明：
# - 本文件仅为示例，请复制为 `.env` 并填写真实值。
# - `.env` 已在 `.gitignore` 中忽略，**不要**提交真实密钥到 GitHub。
#

# ---- Neo4j ----
# 如果你用 docker-compose 启动 Neo4j，可直接改这里；Compose 会自动读取根目录 `.env`。
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=please_change_me

# ---- LLM（默认：DeepSeek，OpenAI-compatible）----
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-chat
DEEPSEEK_API_KEY=
# 可选：自定义 base url（不填则按 provider 自动推断）
# LLM_BASE_URL=https://api.deepseek.com/v1
# 可选：统一 key（优先级高于 provider-specific key）
# LLM_API_KEY=

# ---- Embeddings（必需：RAG/相似度/聚类核心功能依赖）----
# 推荐：SiliconFlow + BAAI/bge-m3
EMBEDDING_PROVIDER=siliconflow
EMBEDDING_MODEL=BAAI/bge-m3
SILICONFLOW_API_KEY=
# 可选：SiliconFlow 有 .cn / .com 两套域名
# EMBEDDING_BASE_URL=https://api.siliconflow.com/v1
# 可选：统一 key（优先级高于 provider-specific key）
# EMBEDDING_API_KEY=

# ---- 其他 ----
# DATA_ROOT=..

# ---- Phase1 抽取门禁（可选）----
# 是否允许 weak 支持的 claim 进入 validated 轨道（默认 false）
# PHASE1_GATE_ALLOW_WEAK=false
